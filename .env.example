# AI Speaker – miljøvariabler
# Kopier til .env og udfyld værdierne

# Din maskins IP – til adgang fra netværket (fx 192.168.1.10)
# Find din IP: Mac: Systemindstillinger > Netværk | Windows: ipconfig
HOST_IP=172.20.10.2

# Google OAuth (til login)
REACT_APP_GOOGLE_CLIENT_ID=din_google_client_id

# Google Gemini API
GOOGLE_GEMINI_API_KEY=din_gemini_api_key

# OpenAI (til chat)
OPENAI_API_KEY=din_openai_api_key

# Vejr (OpenWeatherMap)
OPENWEATHER_API_KEY=din_openweather_api_key

# Spotify OAuth – brug 127.0.0.1 (ikke localhost)
SPOTIFY_CLIENT_ID=din_spotify_client_id
SPOTIFY_CLIENT_SECRET=din_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://172.20.10.2:3000/opsætning?callback=spotify
GOOGLE_REDIRECT_URI=http://172.20.10.2:3000/opsætning?callback=google-calendar

# JWT til sessions
JWT_SECRET=et_tilfældigt_hemmeligt_til_produktion
